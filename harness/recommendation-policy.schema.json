{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/stock-alpaca/recommendation-policy.schema.json",
  "title": "Recommendation Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_id",
    "updated_at",
    "policy_version",
    "strategy_status",
    "cadence_policy",
    "promotion_criteria",
    "source_confidence",
    "after_hours_policy",
    "universe_policy"
  ],
  "properties": {
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "policy_version": {
      "type": "string",
      "minLength": 1
    },
    "strategy_status": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status", "auto_orders_allowed", "evidence_metrics", "blockers"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["observation_only", "active_dry_run_candidate", "auto_eligible_paper", "rejected"]
          },
          "auto_orders_allowed": {
            "type": "boolean"
          },
          "promotion_status": {
            "type": "string"
          },
          "evidence_metrics": {
            "type": "object",
            "additionalProperties": true
          },
          "active_filters": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blockers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required_next_evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "promotion_criteria": {
      "type": "object",
      "additionalProperties": true
    },
    "cadence_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scheduled_interval_minutes",
        "market_hours_only",
        "alpaca_clock_preflight_required",
        "launchd_minutes",
        "launchd_hour_window_kst",
        "overlap_behavior",
        "off_market_behavior",
        "market_open_validation_run_kst",
        "notes"
      ],
      "properties": {
        "scheduled_interval_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "launchd_minutes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 59
          }
        },
        "launchd_hour_window_kst": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 23
          }
        },
        "market_hours_only": {
          "type": "boolean"
        },
        "alpaca_clock_preflight_required": {
          "type": "boolean"
        },
        "overlap_behavior": {
          "type": "string"
        },
        "off_market_behavior": {
          "type": "string"
        },
        "market_open_validation_run_kst": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "source_confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum_for_new_buy", "provider_gap_blocks_order", "timestamp_basis"],
      "properties": {
        "minimum_for_new_buy": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "provider_gap_blocks_order": {
          "type": "boolean"
        },
        "timestamp_basis": {
          "type": "string"
        },
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "mcp_gate_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "core_servers",
        "research_servers",
        "all_research_must_be_attempted",
        "min_research_confirmations_for_actionable",
        "min_research_confirmations_for_submit",
        "core_gate_blocks_order",
        "provider_gap_blocks_order",
        "provider_gap_creates_recheck_candidate",
        "recheck_label"
      ],
      "properties": {
        "core_servers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "research_servers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "all_research_must_be_attempted": {
          "type": "boolean"
        },
        "min_research_confirmations_for_actionable": {
          "type": "integer",
          "minimum": 0
        },
        "min_research_confirmations_for_submit": {
          "type": "integer",
          "minimum": 0
        },
        "core_gate_blocks_order": {
          "type": "boolean"
        },
        "provider_gap_blocks_order": {
          "type": "string"
        },
        "provider_gap_creates_recheck_candidate": {
          "type": "boolean"
        },
        "recheck_label": {
          "type": "string"
        }
      }
    },
    "risk_trim_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allow_core_only_risk_trim",
        "requires_alpaca_position_quote_order_state",
        "research_mcp_full_pass_required",
        "allowed_reasons",
        "trim_requires"
      ],
      "properties": {
        "allow_core_only_risk_trim": {
          "type": "boolean"
        },
        "requires_alpaca_position_quote_order_state": {
          "type": "boolean"
        },
        "research_mcp_full_pass_required": {
          "type": "boolean"
        },
        "evaluation_order": {
          "type": "string",
          "enum": ["before_new_buys", "after_new_buys"]
        },
        "decouple_from_buy_entry_window": {
          "type": "boolean"
        },
        "decouple_from_buy_budget": {
          "type": "boolean"
        },
        "allowed_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "trim_requires": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "active_trim_triggers": {
          "type": "object",
          "additionalProperties": {
            "type": ["number", "integer", "boolean", "string"]
          }
        },
        "sell_candidate_diagnostics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "top_n",
            "include_no_trigger_candidates",
            "include_blocked_by_gate_candidates",
            "rank_by",
            "required_fields"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "top_n": {
              "type": "integer",
              "minimum": 0
            },
            "include_no_trigger_candidates": {
              "type": "boolean"
            },
            "include_blocked_by_gate_candidates": {
              "type": "boolean"
            },
            "rank_by": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "required_fields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "validation_lifecycle": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "applies_to",
            "review_horizons",
            "required_decisions",
            "block_add_when_review_due",
            "open_position_conclusions_are_interim",
            "record_missing_review_as_sell_candidate_diagnostic"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "applies_to": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "review_horizons": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["1D", "5D", "20D"]
              }
            },
            "required_decisions": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["hold", "add", "trim", "close"]
              }
            },
            "block_add_when_review_due": {
              "type": "boolean"
            },
            "open_position_conclusions_are_interim": {
              "type": "boolean"
            },
            "record_missing_review_as_sell_candidate_diagnostic": {
              "type": "boolean"
            }
          }
        },
        "rotation_trim": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "reason",
            "default_trim_fraction_pct",
            "held_expected_excess_return_floor_pct",
            "replacement_min_confidence_score",
            "replacement_expected_excess_margin_pct",
            "require_replacement_passes_buy_gates",
            "require_held_position_passes_sell_gates",
            "require_distinct_or_lower_correlation_replacement",
            "do_not_rotate_same_day_validation_buy"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "reason": {
              "type": "string"
            },
            "default_trim_fraction_pct": {
              "type": "number",
              "minimum": 0
            },
            "held_expected_excess_return_floor_pct": {
              "type": "number"
            },
            "replacement_min_confidence_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "replacement_expected_excess_margin_pct": {
              "type": "number",
              "minimum": 0
            },
            "require_replacement_passes_buy_gates": {
              "type": "boolean"
            },
            "require_held_position_passes_sell_gates": {
              "type": "boolean"
            },
            "require_distinct_or_lower_correlation_replacement": {
              "type": "boolean"
            },
            "do_not_rotate_same_day_validation_buy": {
              "type": "boolean"
            }
          }
        },
        "portfolio_target_bands": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "themes": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/target_band"
              }
            },
            "factors": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/target_band"
              }
            },
            "correlated_clusters": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/target_band"
              }
            }
          }
        }
      }
    },
    "paper_validation_execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "purpose",
        "enabled_for_hourly_autopilot",
        "enabled_for_market_open_pulse",
        "prefer_small_validation_order_when_gates_pass",
        "do_not_force_trade_when_any_hard_gate_fails",
        "hard_gates",
        "opening_window",
        "validation_order_sizing",
        "candidate_floor",
        "no_action_diagnostics"
      ],
      "properties": {
        "purpose": {
          "type": "string"
        },
        "enabled_for_hourly_autopilot": {
          "type": "boolean"
        },
        "enabled_for_market_open_pulse": {
          "type": "boolean"
        },
        "prefer_small_validation_order_when_gates_pass": {
          "type": "boolean"
        },
        "do_not_force_trade_when_any_hard_gate_fails": {
          "type": "boolean"
        },
        "hard_gates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "opening_window": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "local_time_zone", "start_time", "end_time", "objective"],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "local_time_zone": {
              "type": "string"
            },
            "start_time": {
              "type": "string"
            },
            "end_time": {
              "type": "string"
            },
            "objective": {
              "type": "string"
            }
          }
        },
        "validation_order_sizing": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allocation_mode",
            "default_qty",
            "max_new_buy_orders_per_run",
            "max_validation_notional_pct_per_order",
            "max_validation_notional_pct_per_day",
            "prefer_existing_highest_ranked_actionable_candidate",
            "allow_existing_position_add_only_if_position_cap_passes"
          ],
          "properties": {
            "allocation_mode": {
              "type": "string"
            },
            "default_qty": {
              "type": "integer",
              "minimum": 1
            },
            "max_new_buy_orders_per_run": {
              "type": "integer",
              "minimum": 0
            },
            "max_validation_notional_pct_per_order": {
              "type": "number",
              "minimum": 0
            },
            "max_validation_notional_pct_per_day": {
              "type": "number",
              "minimum": 0
            },
            "prefer_existing_highest_ranked_actionable_candidate": {
              "type": "boolean"
            },
            "allow_existing_position_add_only_if_position_cap_passes": {
              "type": "boolean"
            },
            "allow_multiple_candidates_per_run": {
              "type": "boolean"
            },
            "prefer_different_clusters_for_additional_orders": {
              "type": "boolean"
            },
            "max_same_cluster_new_buys_per_run": {
              "type": "integer",
              "minimum": 1
            },
            "cash_ratio_floor_for_second_order": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "cash_ratio_floor_for_third_order": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "cash_ratio_floor_for_additional_orders": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "target_exposure_path": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "current_to_accelerate_until_ratio",
                "selective_allocation_until_ratio",
                "max_policy_target_ratio",
                "max_new_exposure_pct_per_run_normal",
                "max_new_exposure_pct_per_run_high_conviction",
                "prefer_rebalance_over_new_buy_above_ratio"
              ],
              "properties": {
                "current_to_accelerate_until_ratio": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "selective_allocation_until_ratio": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "max_policy_target_ratio": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "max_new_exposure_pct_per_run_normal": {
                  "type": "number",
                  "minimum": 0
                },
                "max_new_exposure_pct_per_run_high_conviction": {
                  "type": "number",
                  "minimum": 0
                },
                "prefer_rebalance_over_new_buy_above_ratio": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            },
            "open_order_policy": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "block_same_symbol_side_new_buy",
                "block_same_correlated_cluster_new_buy_when_open_order_exists",
                "allow_different_cluster_new_buy_when_open_orders_are_fresh",
                "require_lifecycle_gate_pass"
              ],
              "properties": {
                "block_same_symbol_side_new_buy": {
                  "type": "boolean"
                },
                "block_same_correlated_cluster_new_buy_when_open_order_exists": {
                  "type": "boolean"
                },
                "allow_different_cluster_new_buy_when_open_orders_are_fresh": {
                  "type": "boolean"
                },
                "require_lifecycle_gate_pass": {
                  "type": "boolean"
                }
              }
            },
            "confidence_tiers": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "min_confidence_score", "max_notional_pct", "max_qty"],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "min_confidence_score": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "max_notional_pct": {
                    "type": "number",
                    "minimum": 0
                  },
                  "max_qty": {
                    "type": "integer",
                    "minimum": 1
                  }
                }
              }
            }
          }
        },
        "candidate_floor": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "minimum_confidence_score",
            "allow_medium_source_confidence",
            "require_positive_expected_excess_return",
            "require_no_thesis_break"
          ],
          "properties": {
            "minimum_confidence_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "allow_medium_source_confidence": {
              "type": "boolean"
            },
            "require_positive_expected_excess_return": {
              "type": "boolean"
            },
            "require_no_thesis_break": {
              "type": "boolean"
            }
          }
        },
        "no_action_diagnostics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "record_first_blocking_gate",
            "record_next_relaxation_candidate",
            "record_top_recheck_candidates"
          ],
          "properties": {
            "record_first_blocking_gate": {
              "type": "boolean"
            },
            "record_next_relaxation_candidate": {
              "type": "boolean"
            },
            "record_top_recheck_candidates": {
              "type": "integer",
              "minimum": 0
            },
            "record_top_sell_candidates": {
              "type": "boolean"
            },
            "record_validation_lifecycle_due": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "after_hours_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled_for_explicit_autopilot_runs",
        "enabled_for_regular_hourly_autopilot",
        "session_name",
        "artifact_tag",
        "review_bucket",
        "order_id_prefix",
        "cadence",
        "separate_from_regular_validation",
        "require_extended_hours_flag",
        "require_separate_order_budget",
        "require_separate_review_bucket",
        "allowed_sides",
        "max_new_buy_orders_per_run",
        "max_new_orders_per_session",
        "default_qty",
        "max_notional_pct_per_order",
        "max_spread_pct",
        "max_quote_age_minutes_submit",
        "limit_guardrail_ratio",
        "cancel_unfilled_after_minutes",
        "hard_gates",
        "review_horizons"
      ],
      "properties": {
        "enabled_for_explicit_autopilot_runs": {
          "type": "boolean"
        },
        "enabled_for_regular_hourly_autopilot": {
          "type": "boolean"
        },
        "session_name": {
          "type": "string",
          "const": "after_hours"
        },
        "artifact_tag": {
          "type": "string",
          "minLength": 1
        },
        "review_bucket": {
          "type": "string",
          "minLength": 1
        },
        "order_id_prefix": {
          "type": "string",
          "minLength": 1
        },
        "cadence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scheduled_interval_minutes",
            "launchd_minutes",
            "launchd_hour_window_kst",
            "overlap_behavior",
            "regular_market_behavior"
          ],
          "properties": {
            "scheduled_interval_minutes": {
              "type": "integer",
              "minimum": 1
            },
            "launchd_minutes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "integer",
                "minimum": 0,
                "maximum": 59
              }
            },
            "launchd_hour_window_kst": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "integer",
                "minimum": 0,
                "maximum": 23
              }
            },
            "overlap_behavior": {
              "type": "string"
            },
            "regular_market_behavior": {
              "type": "string"
            }
          }
        },
        "separate_from_regular_validation": {
          "type": "boolean"
        },
        "require_extended_hours_flag": {
          "type": "boolean"
        },
        "require_separate_order_budget": {
          "type": "boolean"
        },
        "require_separate_review_bucket": {
          "type": "boolean"
        },
        "allowed_sides": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["buy", "sell"]
          }
        },
        "max_new_buy_orders_per_run": {
          "type": "integer",
          "minimum": 0
        },
        "max_new_orders_per_session": {
          "type": "integer",
          "minimum": 0
        },
        "default_qty": {
          "type": "integer",
          "minimum": 1
        },
        "max_notional_pct_per_order": {
          "type": "number",
          "minimum": 0
        },
        "max_spread_pct": {
          "type": "number",
          "minimum": 0
        },
        "max_quote_age_minutes_submit": {
          "type": "number",
          "minimum": 0
        },
        "limit_guardrail_ratio": {
          "type": "number",
          "minimum": 0
        },
        "cancel_unfilled_after_minutes": {
          "type": "integer",
          "minimum": 0
        },
        "hard_gates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "review_horizons": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "universe_policy": {
      "type": "object",
      "additionalProperties": true
    },
    "alpha_signal_layer": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "execution_portfolio_layer": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retired_filters": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "target_band": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_ratio",
        "warning_ratio",
        "hard_cap_source",
        "above_warning_behavior"
      ],
      "properties": {
        "target_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "warning_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "hard_cap_source": {
          "type": "string"
        },
        "above_warning_behavior": {
          "type": "object",
          "additionalProperties": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
