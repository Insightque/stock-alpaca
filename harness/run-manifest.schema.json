{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/stock-alpaca/run-manifest.schema.json",
  "title": "Trading Harness Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "mode",
    "paper",
    "created_at",
    "git_commit",
    "prompt_file_sha",
    "risk_policy_version",
    "recommendation_policy_sha",
    "schema_version",
    "mcp_servers_used",
    "mcp_failures",
    "mcp_coverage",
    "data_cutoff_time",
    "market_clock_checked_at",
    "source_refs",
    "risk_check_result",
    "data_manifest"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["dry_run", "submit", "research", "review", "wiki_lint"]
    },
    "paper": {
      "type": "boolean",
      "const": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "git_commit": {
      "type": "string",
      "minLength": 1
    },
    "prompt_file_sha": {
      "type": "string",
      "minLength": 1
    },
    "risk_policy_version": {
      "type": "string",
      "const": "medium-risk-v1.1"
    },
    "recommendation_policy_sha": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "enum": ["1.1", "1.2", "1.3"]
    },
    "mcp_servers_used": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mcp_failures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["server", "reason"],
        "properties": {
          "server": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "mcp_coverage": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "server",
          "required",
          "queried",
          "used_in_score",
          "outcome",
          "checked_at",
          "source_refs",
          "gap_reason"
        ],
        "properties": {
          "server": {
            "type": "string",
            "enum": ["alpaca", "sec-edgar", "alpha-vantage", "fred", "firecrawl", "yahoo-finance"]
          },
          "required": {
            "type": "boolean"
          },
          "queried": {
            "type": "boolean"
          },
          "used_in_score": {
            "type": "boolean"
          },
          "outcome": {
            "type": "string",
            "enum": ["pass", "usable", "ok", "gap", "failed", "unavailable", "not_applicable"]
          },
          "checked_at": {
            "type": "string"
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "gap_reason": {
            "type": "string"
          },
          "gap_category": {
            "type": "string",
            "enum": [
              "timeout",
              "cancelled",
              "dns",
              "auth",
              "empty_response",
              "provider_error",
              "wrapper_error",
              "not_applicable",
              "unknown"
            ]
          },
          "retry_count": {
            "type": "integer",
            "minimum": 0
          },
          "first_blocking_gate": {
            "type": "string"
          }
        }
      }
    },
    "mcp_gate_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "core_servers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "research_servers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "min_research_confirmations": {
          "type": "integer",
          "minimum": 0
        },
        "all_research_must_be_attempted": {
          "type": "boolean"
        },
        "provider_gap_blocks_order": {
          "type": "boolean"
        }
      }
    },
    "recommendation_actionability": {
      "type": "string",
      "enum": [
        "actionable",
        "order_candidate",
        "submit_candidate",
        "actionable_if_provider_recovered",
        "non_actionable_research",
        "blocked"
      ]
    },
    "universe_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "universe_source",
        "scope_limited_by_user",
        "symbols_considered",
        "symbols_loaded",
        "minimum_required_symbols",
        "benchmarks",
        "screening_method",
        "pre_mcp_shortlist",
        "final_candidates",
        "passed",
        "gap_reason"
      ],
      "properties": {
        "universe_source": {
          "type": "string",
          "minLength": 1
        },
        "scope_limited_by_user": {
          "type": "boolean"
        },
        "symbols_considered": {
          "type": "integer",
          "minimum": 0
        },
        "symbols_loaded": {
          "type": "integer",
          "minimum": 0
        },
        "minimum_required_symbols": {
          "type": "integer",
          "minimum": 0
        },
        "benchmarks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "screening_method": {
          "type": "string",
          "minLength": 1
        },
        "pre_mcp_shortlist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "final_candidates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "passed": {
          "type": "boolean"
        },
        "gap_reason": {
          "type": "string"
        }
      }
    },
    "data_cutoff_time": {
      "type": "string",
      "format": "date-time"
    },
    "market_clock_checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "order_plan_path": {
      "type": "string"
    },
    "risk_check_result": {
      "type": "object",
      "additionalProperties": true
    },
    "data_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_feed",
        "adjusted_prices",
        "timezone",
        "trading_calendar",
        "symbols_requested",
        "symbols_loaded",
        "missing_symbol_dates",
        "stale_quotes",
        "corporate_actions_checked",
        "survivorship_bias_controlled"
      ],
      "properties": {
        "source_feed": {
          "type": "string",
          "minLength": 1
        },
        "bar_interval": {
          "type": "string"
        },
        "adjusted_prices": {
          "type": "boolean"
        },
        "timezone": {
          "type": "string",
          "minLength": 1
        },
        "trading_calendar": {
          "type": "string",
          "minLength": 1
        },
        "symbols_requested": {
          "type": "integer",
          "minimum": 0
        },
        "symbols_loaded": {
          "type": "integer",
          "minimum": 0
        },
        "missing_symbol_dates": {
          "type": "integer",
          "minimum": 0
        },
        "stale_quotes": {
          "type": "integer",
          "minimum": 0
        },
        "corporate_actions_checked": {
          "type": "boolean"
        },
        "survivorship_bias_controlled": {
          "type": "boolean"
        },
        "dataset_hash": {
          "type": "string"
        },
        "raw_input_file": {
          "type": "string"
        }
      }
    },
    "submitted_order_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "post_trade_check_path": {
      "type": "string"
    }
  }
}
