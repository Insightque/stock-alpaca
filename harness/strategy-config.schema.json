{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/stock-alpaca/strategy-config.schema.json",
  "title": "Trading Harness Strategy Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "strategy_id",
    "strategy_version",
    "policy_status",
    "universe_id",
    "benchmarks",
    "bar_source",
    "bar_interval",
    "asof_alignment",
    "train_validation",
    "cost_model",
    "filters",
    "selection"
  ],
  "properties": {
    "strategy_id": {
      "type": "string",
      "minLength": 1
    },
    "strategy_version": {
      "type": "string",
      "minLength": 1
    },
    "policy_status": {
      "type": "string",
      "enum": ["observation_only", "active_dry_run_candidate", "auto_eligible_paper", "comparison_only", "rejected"]
    },
    "auto_orders_allowed": {
      "type": "boolean"
    },
    "universe_id": {
      "type": "string",
      "minLength": 1
    },
    "symbols": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "benchmarks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "bar_source": {
      "type": "string",
      "minLength": 1
    },
    "bar_interval": {
      "type": "string",
      "minLength": 1
    },
    "asof_alignment": {
      "type": "string",
      "enum": ["date_key"]
    },
    "train_validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "train_months", "validation_months"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["walk_forward", "fixed_split"]
        },
        "train_months": {
          "type": "integer",
          "minimum": 1
        },
        "validation_months": {
          "type": "integer",
          "minimum": 1
        },
        "rolling_step_months": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "cost_model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slippage_bps", "spread_bps", "reject_unfilled_limit_orders"],
      "properties": {
        "slippage_bps": {
          "type": "number",
          "minimum": 0
        },
        "spread_bps": {
          "type": "number",
          "minimum": 0
        },
        "reject_unfilled_limit_orders": {
          "type": "boolean"
        },
        "fee_bps": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "filters": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "string", "boolean"]
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["top_n", "theme_cap", "score"],
      "properties": {
        "top_n": {
          "type": "integer",
          "minimum": 1
        },
        "theme_cap": {
          "type": "integer",
          "minimum": 1
        },
        "score": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "promotion_required": {
      "type": "boolean"
    }
  }
}
