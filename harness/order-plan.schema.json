{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/stock-alpaca/order-plan.schema.json",
  "title": "Alpaca Paper Trading Order Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "schema_version",
    "risk_policy_version",
    "recommendation_policy_sha",
    "created_at",
    "mode",
    "paper",
    "market",
    "account",
    "positions",
    "orders",
    "source_refs"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "const": "1.2"
    },
    "risk_policy_version": {
      "type": "string",
      "const": "medium-risk-v1.1"
    },
    "recommendation_policy_sha": {
      "type": "string",
      "minLength": 1,
      "description": "Preferred format is sha256:<64 lowercase hex chars>. Use unavailable only when the reason is recorded in source_refs."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "type": "string",
      "enum": ["dry_run", "submit"]
    },
    "paper": {
      "type": "boolean",
      "const": true
    },
    "market": {
      "type": "object",
      "additionalProperties": false,
      "required": ["is_open", "checked_at"],
      "properties": {
        "is_open": {
          "type": "boolean"
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        },
        "next_open": {
          "type": "string",
          "format": "date-time"
        },
        "next_close": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "account": {
      "type": "object",
      "additionalProperties": false,
      "required": ["portfolio_value", "cash", "buying_power"],
      "properties": {
        "portfolio_value": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "cash": {
          "type": "number",
          "minimum": 0
        },
        "buying_power": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "const": "USD"
        },
        "daily_realized_loss": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "positions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "symbol",
          "qty",
          "market_value",
          "theme",
          "factor",
          "volatility_bucket",
          "speculative_flag",
          "liquidity_bucket",
          "source_confidence"
        ],
        "properties": {
          "symbol": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9.-]{0,9}$"
          },
          "asset_type": {
            "type": "string",
            "enum": ["stock", "etf"]
          },
          "qty": {
            "type": "number"
          },
          "market_value": {
            "type": "number"
          },
          "avg_entry_price": {
            "type": "number"
          },
          "current_price": {
            "type": "number"
          },
          "theme": {
            "type": "string",
            "minLength": 1
          },
          "factor": {
            "type": "string",
            "minLength": 1
          },
          "volatility_bucket": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "speculative_flag": {
            "type": "boolean"
          },
          "liquidity_bucket": {
            "type": "string",
            "enum": ["mega", "large", "medium", "small", "unknown"]
          },
          "source_confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "correlated_cluster": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "open_orders": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["symbol", "side", "qty", "status", "submitted_at", "age_minutes"],
        "properties": {
          "symbol": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9.-]{0,9}$"
          },
          "side": {
            "type": "string",
            "enum": ["buy", "sell"]
          },
          "qty": {
            "type": "number",
            "minimum": 0
          },
          "filled_qty": {
            "type": "number",
            "minimum": 0
          },
          "status": {
            "type": "string",
            "enum": ["new", "accepted", "partially_filled", "pending_replace", "pending_cancel", "held"]
          },
          "client_order_id": {
            "type": "string"
          },
          "decision_id": {
            "type": "string"
          },
          "submitted_at": {
            "type": "string",
            "format": "date-time"
          },
          "age_minutes": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "risk_inputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "policy_turnover_ratio": {
          "type": "number",
          "minimum": 0
        },
        "weekly_turnover_ratio": {
          "type": "number",
          "minimum": 0
        },
        "stop_triggered_orders_today": {
          "type": "integer",
          "minimum": 0
        },
        "risk_recomputed_after_partial_fill": {
          "type": "boolean"
        }
      }
    },
    "orders": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "symbol",
          "asset_type",
          "asset_status",
          "asset_tradable",
          "side",
          "order_type",
          "time_in_force",
          "qty",
          "limit_price",
          "reference_price",
          "quote_age_minutes",
          "quote_captured_at",
          "asset_checked_at",
          "theme",
          "factor",
          "volatility_bucket",
          "speculative_flag",
          "liquidity_bucket",
          "source_confidence",
          "strategy_id",
          "strategy_version",
          "policy_status",
          "expected_excess_return_20d_pct",
          "expected_adverse_move_20d_pct",
          "confidence_score",
          "sizing_basis",
          "entry_style",
          "max_additional_entry_count",
          "liquidity",
          "client_order_id",
          "decision_id",
          "source_refs",
          "rationale"
        ],
        "properties": {
          "symbol": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9.-]{0,9}$"
          },
          "asset_type": {
            "type": "string",
            "enum": ["stock", "etf"]
          },
          "asset_status": {
            "type": "string",
            "enum": ["active"]
          },
          "asset_tradable": {
            "type": "boolean",
            "const": true
          },
          "side": {
            "type": "string",
            "enum": ["buy", "sell"]
          },
          "order_type": {
            "type": "string",
            "const": "limit"
          },
          "time_in_force": {
            "type": "string",
            "const": "day"
          },
          "qty": {
            "type": "integer",
            "minimum": 1
          },
          "limit_price": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "reference_price": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "quote_age_minutes": {
            "type": "number",
            "minimum": 0
          },
          "quote_captured_at": {
            "type": "string",
            "format": "date-time"
          },
          "asset_checked_at": {
            "type": "string",
            "format": "date-time"
          },
          "theme": {
            "type": "string",
            "minLength": 1
          },
          "factor": {
            "type": "string",
            "minLength": 1
          },
          "volatility_bucket": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "speculative_flag": {
            "type": "boolean"
          },
          "liquidity_bucket": {
            "type": "string",
            "enum": ["mega", "large", "medium", "small", "unknown"]
          },
          "source_confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "correlated_cluster": {
            "type": "string",
            "minLength": 1
          },
          "strategy_id": {
            "type": "string",
            "minLength": 1
          },
          "strategy_version": {
            "type": "string",
            "minLength": 1
          },
          "policy_status": {
            "type": "string",
            "enum": [
              "observation_only",
              "active_dry_run_candidate",
              "auto_eligible_paper",
              "comparison_only",
              "rejected"
            ]
          },
          "expected_excess_return_20d_pct": {
            "type": "number"
          },
          "expected_adverse_move_20d_pct": {
            "type": "number",
            "maximum": 0
          },
          "confidence_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "sizing_basis": {
            "type": "string",
            "minLength": 1
          },
          "entry_style": {
            "type": "string",
            "enum": ["staged", "single", "trim", "exit"]
          },
          "max_additional_entry_count": {
            "type": "integer",
            "minimum": 0
          },
          "liquidity": {
            "type": "object",
            "additionalProperties": false,
            "required": ["spread_pct", "avg_daily_dollar_volume", "quote_source"],
            "properties": {
              "bid": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "ask": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "spread_pct": {
                "type": "number",
                "minimum": 0
              },
              "avg_daily_dollar_volume": {
                "type": "number",
                "minimum": 0
              },
              "quote_source": {
                "type": "string",
                "enum": ["alpaca", "research_mcp", "manual"]
              },
              "measured_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "client_order_id": {
            "type": "string",
            "minLength": 1
          },
          "decision_id": {
            "type": "string",
            "minLength": 1
          },
          "historical_asof": {
            "type": "string",
            "format": "date-time"
          },
          "review_horizons": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["1D", "5D", "20D"]
            }
          },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "manifest_path": {
      "type": "string"
    }
  }
}
