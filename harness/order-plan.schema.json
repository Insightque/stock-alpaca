{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/stock-alpaca/order-plan.schema.json",
  "title": "Alpaca Paper Trading Order Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "schema_version",
    "risk_policy_version",
    "recommendation_policy_sha",
    "created_at",
    "mode",
    "paper",
    "market",
    "account",
    "positions",
    "orders",
    "source_refs"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "const": "1.1"
    },
    "risk_policy_version": {
      "type": "string",
      "const": "medium-risk-v1"
    },
    "recommendation_policy_sha": {
      "type": "string",
      "minLength": 1,
      "description": "Preferred format is sha256:<64 lowercase hex chars>. Use unavailable only when the reason is recorded in source_refs."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "type": "string",
      "enum": ["dry_run", "submit"]
    },
    "paper": {
      "type": "boolean",
      "const": true
    },
    "market": {
      "type": "object",
      "additionalProperties": false,
      "required": ["is_open", "checked_at"],
      "properties": {
        "is_open": {
          "type": "boolean"
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        },
        "next_open": {
          "type": "string",
          "format": "date-time"
        },
        "next_close": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "account": {
      "type": "object",
      "additionalProperties": false,
      "required": ["portfolio_value", "cash", "buying_power"],
      "properties": {
        "portfolio_value": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "cash": {
          "type": "number",
          "minimum": 0
        },
        "buying_power": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "const": "USD"
        }
      }
    },
    "positions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["symbol", "qty", "market_value"],
        "properties": {
          "symbol": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9.-]{0,9}$"
          },
          "asset_type": {
            "type": "string",
            "enum": ["stock", "etf"]
          },
          "qty": {
            "type": "number"
          },
          "market_value": {
            "type": "number"
          },
          "avg_entry_price": {
            "type": "number"
          },
          "current_price": {
            "type": "number"
          }
        }
      }
    },
    "orders": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "symbol",
          "asset_type",
          "side",
          "order_type",
          "time_in_force",
          "qty",
          "limit_price",
          "reference_price",
          "quote_age_minutes",
          "quote_captured_at",
          "asset_checked_at",
          "source_refs",
          "rationale"
        ],
        "properties": {
          "symbol": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9.-]{0,9}$"
          },
          "asset_type": {
            "type": "string",
            "enum": ["stock", "etf"]
          },
          "asset_status": {
            "type": "string",
            "enum": ["active"]
          },
          "asset_tradable": {
            "type": "boolean",
            "const": true
          },
          "side": {
            "type": "string",
            "enum": ["buy", "sell"]
          },
          "order_type": {
            "type": "string",
            "const": "limit"
          },
          "time_in_force": {
            "type": "string",
            "const": "day"
          },
          "qty": {
            "type": "integer",
            "minimum": 1
          },
          "limit_price": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "reference_price": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "quote_age_minutes": {
            "type": "number",
            "minimum": 0
          },
          "quote_captured_at": {
            "type": "string",
            "format": "date-time"
          },
          "asset_checked_at": {
            "type": "string",
            "format": "date-time"
          },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "client_order_id": {
            "type": "string"
          },
          "decision_id": {
            "type": "string"
          },
          "historical_asof": {
            "type": "string",
            "format": "date-time"
          },
          "review_horizons": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["1D", "5D", "20D"]
            }
          }
        }
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "manifest_path": {
      "type": "string"
    }
  }
}
